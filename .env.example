# Copy this file to .env and fill in your values
# ragdrift core requires NO API keys. Only --explain needs one.

# Optional: Anthropic API key for --explain flag
ANTHROPIC_API_KEY=

# Optional: Qdrant connection (only needed for ragdrift[vector])
QDRANT_URL=http://localhost:6333

# Optional: Ollama endpoint for --explain --provider ollama
OLLAMA_URL=http://localhost:11434
